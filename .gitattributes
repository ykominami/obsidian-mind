# Normalize line endings to LF on checkin
*.md text=auto eol=lf
*.txt text=auto eol=lf
*.json text=auto eol=lf
*.ts text=auto eol=lf
*.js text=auto eol=lf
*.mjs text=auto eol=lf
*.yaml text=auto eol=lf
*.yml text=auto eol=lf
*.toml text=auto eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.db binary
