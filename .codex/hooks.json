{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$p = if ($env:CODEX_PROJECT_DIR) { $env:CODEX_PROJECT_DIR } else { '.' }; node --experimental-strip-types (Join-Path $p '.claude/scripts/session-start.ts')",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$p = if ($env:CODEX_PROJECT_DIR) { $env:CODEX_PROJECT_DIR } else { '.' }; node --experimental-strip-types (Join-Path $p '.claude/scripts/classify-message.ts')",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$p = if ($env:CODEX_PROJECT_DIR) { $env:CODEX_PROJECT_DIR } else { '.' }; node --experimental-strip-types (Join-Path $p '.claude/scripts/validate-write.ts')",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$p = if ($env:CODEX_PROJECT_DIR) { $env:CODEX_PROJECT_DIR } else { '.' }; node --experimental-strip-types (Join-Path $p '.claude/scripts/qmd-refresh.ts')",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$p = if ($env:CODEX_PROJECT_DIR) { $env:CODEX_PROJECT_DIR } else { '.' }; node --experimental-strip-types (Join-Path $p '.claude/scripts/stop-checklist.ts')",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
