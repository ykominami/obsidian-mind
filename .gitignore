# Obsidian (runtime state, not vault config)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/data.json
.obsidian/graph.json

# OS
.DS_Store
.Trash/

# Claude Code (local settings are personal)
.claude/settings.local.json

# QMD index (local, regenerated)
.qmd/

# Session logs (local transcripts)
thinking/session-logs/

# Node typecheck deps (CI + local dev only; runtime is zero-deps)
node_modules/
.claude/scripts/node_modules/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# AI / IDE tool directories (local, not vault content)
.agents/
.antigravitycli/
.cursor/
.junie/
.kilocode/
.mux/
.windsurf/
.obsidian/plugins/realclaudian/
.obsidian/backlink.json
.obsidian/templates.json
.obsidian/webviewer.json

# Daily notes at vault root (created by Obsidian, not tracked)
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md
